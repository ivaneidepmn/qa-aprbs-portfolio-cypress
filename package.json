{
  "name": "qa-aprbs-portfolio-cypress",
  "version": "1.0.0",
  "description": "Automated QA tests using Cypress for APRBS certification platform",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
"scripts": {
  "cy:run": "cypress run",
  "report:merge": "mochawesome-merge cypress/reports/mochawesome/*.json > cypress/reports/mochawesome.json",
  "report:html": "marge cypress/reports/mochawesome.json -f report -o cypress/reports/html",
  "test": "npm run cy:run && npm run report:merge && npm run report:html"
},
  "devDependencies": {
    "cypress": "13.17.0",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^4.4.1",
    "mochawesome-report-generator": "^6.3.2"
  },
  "keywords": [
    "qa",
    "automation",
    "cypress",
    "testing",
    "e2e",
    "portfolio"
  ],
  "author": "Ivaneide Pires Monteiro do Nascimento",
  "license": "ISC"
}
